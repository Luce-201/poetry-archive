---
// This is the "Frontmatter" where we write JavaScript for Astro.
// We are expecting a "title" to be passed to this layout.
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Navigation Bar -->
    <nav class="navbar">
      <div class="nav-content">
        <a href="/" class="logo">Poetry Archive</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/poems/first-poem">Read</a>
        </div>
      </div>
    </nav>

    <!-- Main Content Area -->
    <main class="container">
      <!-- The <slot /> is the "hole" where your page/poem content gets injected -->
      <slot />
    </main>

  </body>
</html>

<style is:global>
  /* This is our core, cool-toned professional styling */
  :root {
    --bg-color: #f8fafc; /* Very light slate gray */
    --text-main: #1e293b; /* Deep slate */
    --accent: #3b82f6; /* Professional blue */
    --nav-bg: #0f172a; /* Dark slate */
  }

  body {
    margin: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-main);
    line-height: 1.6;
  }

  /* Navigation Styling */
  .navbar {
    background-color: var(--nav-bg);
    padding: 1rem 0;
  }

  .nav-content {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 20px;
  }

  .logo {
    color: white;
    font-size: 1.5rem;
    font-weight: bold;
    text-decoration: none;
  }

  .nav-links a {
    color: #cbd5e1;
    text-decoration: none;
    margin-left: 20px;
    font-size: 1.1rem;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: white;
  }

  /* Content Wrapper */
  .container {
    max-width: 800px; /* Keeps reading lines a comfortable width */
    margin: 40px auto;
    padding: 0 20px;
  }

  /* Styling for Markdown elements */
  h1 { color: var(--text-main); border-bottom: 2px solid #e2e8f0; padding-bottom: 10px; }
  h2 { color: var(--accent); }
</style>
