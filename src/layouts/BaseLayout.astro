---
const { pageTitle } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>

    <style is:global>
      /* --- Light Parchment Theme (Default) --- */
      :root {
        --bg-color: #fdfbf7;
        --text-color: #2c2a29;
        --accent-color: #722f37; /* Wine/Burgundy */
        --card-bg: #f5efe6;
        --border-color: #e3dad0;
        --nav-link: #5a524c;
        --button-bg: #efe8dc;
      }

      /* --- Night Reading Dark Theme --- */
      html.dark {
        --bg-color: #1a1816;
        --text-color: #e6e0d8;
        --accent-color: #e09f67; /* Soft Warm Amber */
        --card-bg: #24211e;
        --border-color: #38332e;
        --nav-link: #b5ada3;
        --button-bg: #2d2925;
      }

      body {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: 'Georgia', serif;
        line-height: 1.7;
        margin: 0;
        padding: 0;
        transition: background-color 0.3s ease, color 0.3s ease;
      }

      /* Header & Navigation */
      header {
        max-width: 850px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border-color);
      }

      .site-brand a {
        font-size: 1.3rem;
        font-weight: bold;
        color: var(--text-color);
        text-decoration: none;
        letter-spacing: 0.5px;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 1.2rem;
      }

      nav a {
        color: var(--nav-link);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      nav a:hover {
        color: var(--accent-color);
      }

      /* Theme Toggle Button */
      .theme-btn {
        background-color: var(--button-bg);
        color: var(--text-color);
        border: 1px solid var(--border-color);
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        cursor: pointer;
        font-family: inherit;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s ease;
      }

      .theme-btn:hover {
        border-color: var(--accent-color);
        color: var(--accent-color);
      }

      /* Main Content Layout */
      main {
        max-width: 850px;
        margin: 2.5rem auto;
        padding: 0 1.5rem;
      }

      h1, h2, h3 {
        color: var(--accent-color);
      }

      a {
        color: var(--accent-color);
      }

      /* Footer */
      footer {
        max-width: 850px;
        margin: 4rem auto 0;
        padding: 2rem 1.5rem;
        border-top: 1px solid var(--border-color);
        text-align: center;
        color: var(--nav-link);
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="site-brand">
        <a href="/">Poetry Archive</a>
      </div>
      <nav>
        <a href="/poems">Poems</a>
        <a href="/poets">Poets</a>
        <a href="/search">Search</a>
        
        <button id="themeToggle" class="theme-btn" aria-label="Toggle light and dark mode">
          <span id="themeIcon">🌙</span>
          <span id="themeText">Dark</span>
        </button>
      </nav>
    </header>

    <main>
      <h1>{pageTitle}</h1>
      <slot />
    </main>

    <footer>
      <p>&copy; Poetry Archive. A sanctuary for classical verse.</p>
    </footer>

    <script>
      const toggleBtn = document.getElementById("themeToggle");
      const themeIcon = document.getElementById("themeIcon");
      const themeText = document.getElementById("themeText");

      const updateUI = (isDark) => {
        if (themeIcon && themeText) {
          themeIcon.textContent = isDark ? "☀️" : "🌙";
          themeText.textContent = isDark ? "Light" : "Dark";
        }
      };

      // Set initial button text based on active root class
      const isInitialDark = document.documentElement.classList.contains("dark");
      updateUI(isInitialDark);

      // Toggle click handler
      toggleBtn?.addEventListener("click", () => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateUI(isDark);
      });
    </script>
  </body>
</html>