---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Modern Vite globbing for Astro 5+
const rawPoets = import.meta.glob('./*.md', { eager: true });
const poets = Object.values(rawPoets);
---

<BaseLayout title="All Poets">
  <h1>Poets Directory</h1>
  <ul>
    {poets.map((poet: any) => (
      <li>
        <a href={poet.url}>{poet.frontmatter?.name || poet.frontmatter?.title || 'Untitled Poet'}</a>
      </li>
    ))}
  </ul>
</BaseLayout>