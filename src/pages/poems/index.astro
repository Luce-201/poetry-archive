---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Modern Vite globbing for Astro 5+
const rawPoems = import.meta.glob('./*.md', { eager: true });
const poems = Object.values(rawPoems);
---

<BaseLayout title="All Poems">
  <h1>Poems Archive</h1>
  <ul>
    {poems.map((poem: any) => (
      <li>
        <a href={poem.url}>{poem.frontmatter?.title || 'Untitled Poem'}</a>
      </li>
    ))}
  </ul>
</BaseLayout>